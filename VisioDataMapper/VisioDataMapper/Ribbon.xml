<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="tabVisioDataMapper" label="Visio画图小助手">
        <group id="groupFlowchart" label="流程图">
          <button id="btnBasicFlowchart" label="基本流程图" showImage="true" imageMso="DiagramProcess" size="large" onAction="OnAction" />
        </group>
        <group id="groupArchitecture" label="架构图">
          <button id="btnOrgChart" label="组织架构图" showImage="true" imageMso="DiagramOrgChart" size="normal" onAction="OnAction" />
          <button id="btnSysArch" label="系统架构图" showImage="true" imageMso="ServerConnection" size="normal" onAction="OnAction" />
          <button id="btnModuleDiagram" label="功能模块图" showImage="true" imageMso="TraceDependents" size="normal" onAction="OnAction" />
        </group>
        <group id="groupSoftwareDatabase" label="软件与数据库">
          <button id="btnEntityAttribute" label="实体属性图" showImage="true" imageMso="TableProperties" size="normal" onAction="OnAction" />
          <button id="btnUseCaseDiagram" label="用例图" showImage="true" imageMso="HappyFace" size="normal" onAction="OnAction" />
          <button id="btnSeqNormal" label="时序图" showImage="true" imageMso="DiagramProcess" size="normal" onAction="OnAction" />
          <menu id="menuDataFlow" label="数据流图" showImage="true" imageMso="DataGraphicEdit" size="normal">
            <button id="btnDataFlowTop" label="顶层数据流图" showImage="true" imageMso="DataGraphicEdit" onAction="OnAction" />
            <button id="btnDataFlowLevel1" label="1层数据流图" showImage="true" imageMso="DiagramProcess" onAction="OnAction" />
            <button id="btnDataFlowLevel2" label="2层数据流图" showImage="true" imageMso="DiagramTarget" onAction="OnAction" />
          </menu>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
